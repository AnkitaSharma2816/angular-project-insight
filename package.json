{
  "name": "angular-project-insight",
  "displayName": "Angular Project Insight",
  "version": "1.0.0",
  "publisher": "AnkitaSharma2816",
  "engines": { "vscode": "^1.85.0" },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [{
